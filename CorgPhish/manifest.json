{
  "name": "CorgPhish",
  "description": "Ai powered phishing detection extension",
  "version": "1.0",
  "manifest_version": 3,
  "options_page": "settings.html",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "tabs"],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"]
    }
  ]
}
